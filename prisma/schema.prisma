generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ---------- Enums ----------

enum Ecosystem {
  LAPANDTOP
  LAPTOPBAZAAR
}

enum ProductCondition {
  NEW
  CERTIFIED_REFURBISHED
}

enum ProductCategory {
  BUSINESS
  STUDENT
  GAMING
  WORKSTATION
  MACBOOK
  TWO_IN_ONE
}

enum Availability {
  IN_STOCK
  LIMITED_STOCK
  ON_ORDER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

enum LeadSource {
  GENERAL_ENQUIRY
  PRODUCT_ENQUIRY
  CORPORATE_ENQUIRY
  REPAIR_BOOKING
  SELL_EXCHANGE
  CALLBACK_REQUEST
}

enum RepairStatus {
  BOOKED
  DIAGNOSING
  IN_PROGRESS
  WAITING_FOR_PARTS
  COMPLETED
  DELIVERED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  MANAGER
  SUPPORT
}

// ---------- Core catalog ----------

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id            String            @id @default(cuid())
  slug          String            @unique
  brand         Brand             @relation(fields: [brandId], references: [id])
  brandId       String
  model         String
  category      ProductCategory
  condition     ProductCondition
  ecosystem     Ecosystem
  priceFrom     Int
  processor     String
  ram           String
  storage       String
  display       String
  graphics      String
  battery       String
  warranty      String
  screenSize    Float
  availability  Availability      @default(IN_STOCK)
  highlights    Json
  images        ProductImage[]
  published     Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  enquiries     Enquiry[]

  @@index([ecosystem, category])
  @@index([brandId])
}

model ProductImage {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  publicId  String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

// ---------- Blog ----------

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String   @db.VarChar(500)
  category    String
  content     Json
  coverImage  String?
  readTime    String
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Leads / Enquiries ----------

model Enquiry {
  id        String     @id @default(cuid())
  source    LeadSource
  status    LeadStatus @default(NEW)
  name      String
  phone     String
  email     String?
  city      String?
  message   String?    @db.Text
  metadata  Json?
  product   Product?   @relation(fields: [productId], references: [id])
  productId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([source, status])
  @@index([createdAt])
}

model CorporateLead {
  id          String     @id @default(cuid())
  status      LeadStatus @default(NEW)
  name        String
  phone       String
  email       String?
  city        String?
  company     String
  quantity    String
  gstin       String?
  message     String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

model RepairRequest {
  id           String       @id @default(cuid())
  trackingCode String       @unique
  status       RepairStatus @default(BOOKED)
  name         String
  phone        String
  email        String?
  city         String?
  location     String?      @db.Text
  device       String
  serialNumber String?
  issueType    String
  message      String?      @db.Text
  mediaUrls    Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
}

model SellExchangeLead {
  id        String     @id @default(cuid())
  status    LeadStatus @default(NEW)
  name      String
  phone     String
  email     String?
  city      String?
  brand     String
  age       String
  condition String
  message   String?    @db.Text
  mediaUrls Json       @default("[]")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
}

// ---------- Customers ----------

model Customer {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ---------- Admin ----------

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(SUPPORT)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
